---
const { project } = Astro.props;
---

<a href={project.html_url} target="_blank" class="min-h-[12em] bg-slate-800/30 rounded-lg p-6 border border-slate-700 flex justify-center items-left flex-col gap-[0.75em] card">
    <div class="card-content">
        <h2 class="card-title">{project.name}</h2>
    </div>
    <p class="card-description">{project.description}</p>
    <div class="languages">
        {project.languages.map((lang) => (
            <span class="language">{lang}</span>
        ))}
    </div>
</a>

<style>
@reference "../styles/global.css";
.card {
    @apply block;
    transition: 0.3s ease;
}

.card:hover {
    @apply border-fuchsia-600 shadow-fuchsia-700/40 shadow-md;
}

.card-content {
    @apply flex items-center mb-2;
}

.card-title {
    @apply flex-1 text-[1.5em] md:text-[1.2em] font-bold text-center text-blue-400;
}

.card-description {
    @apply text-sm text-slate-400;
}

.languages {
    margin-top: auto;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    justify-content: center;
}

.language {
    background-color: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.5em;
    border-radius: 0.3em;
    font-size: 0.9em;
    color: #fff;
}
</style>
